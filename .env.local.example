# Copy this file to .env.local and fill in the values from your Supabase
# project settings: Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Needed for OCR receipt extraction (app/api/extract-receipt) when running
# locally. Create one at vercel.com → your team → AI Gateway → API Keys.
# Not needed in production on Vercel — deployed functions authenticate to
# the Gateway automatically via OIDC.
AI_GATEWAY_API_KEY=
